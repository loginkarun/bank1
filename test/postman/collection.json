              "",
              "pm.test('Decimal calculations are accurate', function () {",
              "    const jsonData = pm.response.json();",
              "    const item = jsonData.items.find(i => i.productId === pm.collectionVariables.get('product_id_1'));",
              "    if (item) {",
              "        const expectedSubtotal = item.price * item.quantity;",
              "        pm.expect(item.subtotal).to.be.closeTo(expectedSubtotal, 0.01);",
              "    }",
              "});",
              "",
              "pm.test('Total has 2 decimal places', function () {",
              "    const jsonData = pm.response.json();",
              "    const totalStr = jsonData.total.toString();",
              "    if (totalStr.includes('.')) {",
              "        const decimals = totalStr.split('.')[1];",
              "        pm.expect(decimals.length).to.be.at.most(2);",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
