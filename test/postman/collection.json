      "name": "Setup - Get Sample Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});",
              "",
              "pm.test('Products exist', function () {",
              "    const products = pm.response.json();",
              "    pm.expect(products.length).to.be.above(0);",
              "    ",
              "    if (products.length >= 2) {",
              "        pm.collectionVariables.set('product_id_1', products[0].id);",
              "        pm.collectionVariables.set('product_id_2', products[1].id);",
              "        console.log('Product 1 ID:', products[0].id);",
              "        console.log('Product 2 ID:', products[1].id);",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/products",
          "host": ["{{base_url}}"],
          "path": ["api", "products"]
        },
        "description": "Setup step to retrieve sample product IDs for testing"
