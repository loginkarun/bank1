                  "pm.test("Item quantity updated correctly", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.items).to.be.an('array');",
                  "    var item = jsonData.items.find(i => i.productId === pm.collectionVariables.get('productId'));",
                  "    if (item) {",
                  "        pm.expect(item.quantity).to.equal(5);",
                  "    }",
                  "});",
                  "",
                  "pm.test("Total recalculated correctly", function () {",
                  "    var jsonData = pm.response.json();",
