    {
      "name": "TC-001: Add New Item to Cart - Happy Path",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has cart structure', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('userId');",
              "    pm.expect(jsonData).to.have.property('items');",
              "    pm.expect(jsonData).to.have.property('total');",
              "});",
              "",
              "pm.test('Cart contains added item', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.items).to.be.an('array');",
              "    pm.expect(jsonData.items.length).to.be.at.least(1);",
              "});",
              "",
              "pm.test('Item quantity is correct', function () {",
              "    const jsonData = pm.response.json();",
              "    const item = jsonData.items.find(i => i.productId === pm.collectionVariables.get('product_id_1'));",
              "    pm.expect(item).to.exist;",
              "    pm.expect(item.quantity).to.equal(2);",
              "});",
              "",
              "pm.test('Total is calculated correctly', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.total).to.be.a('number');",
              "    pm.expect(jsonData.total).to.be.above(0);",
              "});",
              "",
              "pm.test('Response time is acceptable', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "// Save cart ID for subsequent tests",
              "const jsonData = pm.response.json();",
              "pm.collectionVariables.set('cart_id', jsonData.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
