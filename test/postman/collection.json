          "mode": "raw",
          "raw": "{\n  \"productId\": \"{{product_id_1}}\",\n  \"quantity\": 2\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/cart/add",
          "host": ["{{base_url}}"],
          "path": ["api", "cart", "add"]
        },
        "description": "TC-001: Successfully add a new product to an empty cart"
